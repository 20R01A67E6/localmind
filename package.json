{
  "name": "localmind",
  "version": "1.0.0",
  "description": "Fully offline AI chat app powered by Ollama",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "start": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && pyinstaller localmind-backend.spec --distpath dist --workpath build",
    "build:electron": "electron-builder --win",
    "build": "npm run build:frontend && npm run build:electron"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.localmind.app",
    "productName": "LocalMind",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/localmind-backend.exe",
        "to": "localmind-backend.exe"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LocalMind"
    }
  }
}
